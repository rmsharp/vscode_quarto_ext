# Keep the .vsix lean: ship only the bundled extension + metadata.
.vscode/**
.vscode-test/**
.claude/**
.git/**
src/**
test/**
out/**
docs/**
node_modules/**

# Screenshots are referenced by the README (the Marketplace rewrites the
# relative paths to repo raw URLs) — they don't need to ship inside the package.
# The extension icon (media/icon.png) is NOT excluded and still ships.
media/screenshots/**

# Source maps and build inputs
**/*.map
**/*.ts
esbuild.js
tsconfig.json
tsconfig.test.json
vitest.config.ts
.gitignore

# Methodology / project-management artifacts (not part of the extension)
SESSION_RUNNER.md
SAFEGUARDS.md
SESSION_NOTES.md
BOOTSTRAP.md
RECOMMENDED_SKILLS.md
CLAUDE.md
CLAUDE_TEMPLATE.md
CONTEXT.md
CONTEXT_TEMPLATE.md
BACKLOG.md
CHANGELOG.md
ROADMAP.md
methodology_dashboard.py
dashboard.html
dashboard_history.jsonl
**/.DS_Store
